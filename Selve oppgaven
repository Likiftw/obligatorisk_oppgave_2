                funnetKurs = k;
            }
        }

        if (funnetKurs == null)
        {
            Console.WriteLine("Feil: du underviser ikke dette kurset.");
            return;
        }

        if (funnetKurs.Studenter.Count == 0)
        {
            Console.WriteLine("Ingen studenter er påmeldt dette kurset.");
            return;
        }

        Console.Write("StudentID: ");
        string studentID = Console.ReadLine();

        Student funnetStudent = null;
        foreach (Student s in funnetKurs.Studenter)
        {
            if (s.StudentID == studentID)
            {
                funnetStudent = s;
            }
        }

        if (funnetStudent == null)
        {
            Console.WriteLine("Feil: studenten er ikke påmeldt dette kurset.");
            return;
        }

        Console.Write("Karakter (A-F): ");
        string karakter = Console.ReadLine().ToUpper();

        if (karakter != "A" && karakter != "B" && karakter != "C" &&
            karakter != "D" && karakter != "E" && karakter != "F")
        {
            Console.WriteLine("Feil: ugyldig karakter. Bruk A, B, C, D, E eller F.");
            return;
        }

        // Sjekk om studenten allerede har karakter i dette kurset
        foreach (Karakter k in funnetStudent.Karakterer)
        {
            if (k.KursKode == funnetKurs.Kode)
            {
                k.Verdi = karakter;
                Console.WriteLine("Karakter oppdatert til " + karakter + " for " + funnetStudent.Navn);
                return;
            }
        }

        funnetStudent.Karakterer.Add(new Karakter(funnetKurs.Kode, funnetKurs.Navn, karakter));
        Console.WriteLine("Karakter " + karakter + " satt for " + funnetStudent.Navn + " i " + funnetKurs.Navn);
    }

    static void LeggTilPensum(Faglarer faglarer)
    {
        if (faglarer.MineKurs.Count == 0)
        {
            Console.WriteLine("Du underviser ingen kurs.");
            return;
        }

        Console.Write("Kurskode: ");
        string kode = Console.ReadLine();

        Kurs funnetKurs = null;
        foreach (Kurs k in faglarer.MineKurs)
        {
            if (k.Kode.ToLower() == kode.ToLower())
            {
                funnetKurs = k;
            }
        }

        if (funnetKurs == null)
        {
            Console.WriteLine("Feil: du underviser ikke dette kurset.");
            return;
        }

        Console.Write("Pensum (tittel på bok eller ressurs): ");
        string pensum = Console.ReadLine();

        if (string.IsNullOrWhiteSpace(pensum))
        {
            Console.WriteLine("Feil: pensum kan ikke være tomt.");
            return;
        }

        funnetKurs.Pensum.Add(pensum);
        Console.WriteLine("Pensum lagt til i " + funnetKurs.Navn);
    }

