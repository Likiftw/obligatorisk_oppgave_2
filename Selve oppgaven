        if (string.IsNullOrWhiteSpace(kode))
        {
            Console.WriteLine("Feil: kurskode kan ikke være tom.");
            return;
        }

        // Sjekk om kurskode allerede finnes
        foreach (Kurs k in kursliste)
        {
            if (k.Kode.ToLower() == kode.ToLower())
            {
                Console.WriteLine("Feil: et kurs med denne koden finnes allerede.");
                return;
            }
        }

        Console.Write("Kursnavn: ");
        string navn = Console.ReadLine();

        if (string.IsNullOrWhiteSpace(navn))
        {
            Console.WriteLine("Feil: kursnavn kan ikke være tomt.");
            return;
        }

        // Sjekk om kursnavn allerede finnes
        foreach (Kurs k in kursliste)
        {
            if (k.Navn.ToLower() == navn.ToLower())
            {
                Console.WriteLine("Feil: et kurs med dette navnet finnes allerede.");
                return;
            }
        }

        Console.Write("Studiepoeng: ");
        string spInput = Console.ReadLine();
        int studiepoeng;
        if (!int.TryParse(spInput, out studiepoeng) || studiepoeng <= 0)
        {
            Console.WriteLine("Feil: studiepoeng må være et positivt tall.");
            return;
        }

        Console.Write("Maks plasser: ");
        string maksInput = Console.ReadLine();
        int maks;
        if (!int.TryParse(maksInput, out maks) || maks <= 0)
        {
            Console.WriteLine("Feil: maks plasser må være et positivt tall.");
            return;
        }

        Kurs nyttKurs = new Kurs(kode, navn, studiepoeng, maks, faglarer.AnsattID);
        kursliste.Add(nyttKurs);
        faglarer.MineKurs.Add(nyttKurs);
        Console.WriteLine("Kurs opprettet!");
    }

