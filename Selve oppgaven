// ========== KURS ==========
public class Kurs
{
    public string Kode { get; set; }
    public string Navn { get; set; }
    public int Studiepoeng { get; set; }
    public int MaksPlasser { get; set; }
    public List<Student> Studenter { get; set; } = new List<Student>();
    public List<string> Pensum { get; set; } = new List<string>();
    public string FaglarerID { get; set; }

    public Kurs(string kode, string navn, int studiepoeng, int maksPlasser, string faglarerID)
    {
        Kode = kode;
        Navn = navn;
        Studiepoeng = studiepoeng;
        MaksPlasser = maksPlasser;
        FaglarerID = faglarerID;
    }

    public bool MeldPa(Student student)
    {
        if (Studenter.Count >= MaksPlasser)
        {
            return false;
        }

        foreach (Student s in Studenter)
        {
            if (s.StudentID == student.StudentID)
            {
                return false;
            }
        }

        Studenter.Add(student);
        student.Kurs.Add(this);
        return true;
    }

    public bool MeldAv(Student student)
    {
        Student funnetStudent = null;
        foreach (Student s in Studenter)
        {
            if (s.StudentID == student.StudentID)
            {
                funnetStudent = s;
            }
        }

        if (funnetStudent == null)
        {
            return false;
        }

        Studenter.Remove(funnetStudent);
        student.Kurs.Remove(this);
        return true;
    }
}

// ========== BOK ==========
public class Bok
{
    public string ID { get; set; }
    public string Tittel { get; set; }
    public string Forfatter { get; set; }
    public int Aar { get; set; }
    public int AntallEksemplarer { get; set; }
    public int TilgjengeligeEksemplarer { get; set; }

    public Bok(string id, string tittel, string forfatter, int aar, int antall)
    {
        ID = id;
        Tittel = tittel;
        Forfatter = forfatter;
        Aar = aar;
        AntallEksemplarer = antall;
        TilgjengeligeEksemplarer = antall;
    }
}

// ========== LÅN ==========
public class Lan
{
    public Bok Bok { get; set; }
    public Bruker Bruker { get; set; }
    public DateTime Utlaansdato { get; set; }
    public DateTime Returdato { get; set; }
    public bool ErAktiv { get; set; }

    public Lan(Bok bok, Bruker bruker)
    {
        Bok = bok;
        Bruker = bruker;
        Utlaansdato = DateTime.Now;
        ErAktiv = true;
    }
}

// ========== BIBLIOTEK ==========
public class Bibliotek
{
    public List<Bok> Boker { get; set; } = new List<Bok>();
    public List<Lan> Lan { get; set; } = new List<Lan>();

    public void RegistrerBok(Bok bok)
    {
        Boker.Add(bok);
    }

    public bool LanUtBok(string bokID, Bruker bruker)
    {
        Bok funnetBok = null;
        foreach (Bok b in Boker)
        {
            if (b.ID == bokID)
            {
                funnetBok = b;
            }
        }

        if (funnetBok == null)
        {
            return false;
        }

        if (funnetBok.TilgjengeligeEksemplarer <= 0)
        {
            return false;
        }

        funnetBok.TilgjengeligeEksemplarer = funnetBok.TilgjengeligeEksemplarer - 1;
        Lan.Add(new Lan(funnetBok, bruker));
        return true;
    }

    public bool ReturnerBok(string bokID, Bruker bruker)
    {
        Lan funnetLan = null;
        foreach (Lan l in Lan)
        {
            if (l.Bok.ID == bokID && l.Bruker == bruker && l.ErAktiv == true)
            {
                funnetLan = l;
            }
        }

        if (funnetLan == null)
        {
            return false;
        }

        funnetLan.ErAktiv = false;
        funnetLan.Returdato = DateTime.Now;
        funnetLan.Bok.TilgjengeligeEksemplarer = funnetLan.Bok.TilgjengeligeEksemplarer + 1;
        return true;
    }
}

