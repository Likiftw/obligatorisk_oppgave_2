    static void RegistrerBok()
    {
        Console.Write("BokID: ");
        string id = Console.ReadLine();

        if (string.IsNullOrWhiteSpace(id))
        {
            Console.WriteLine("Feil: bokID kan ikke være tom.");
            return;
        }

        // Sjekk om bokID allerede finnes
        foreach (Bok b in bibliotek.Boker)
        {
            if (b.ID == id)
            {
                Console.WriteLine("Feil: en bok med denne ID-en finnes allerede.");
                return;
            }
        }

        Console.Write("Tittel: ");
        string tittel = Console.ReadLine();

        if (string.IsNullOrWhiteSpace(tittel))
        {
            Console.WriteLine("Feil: tittel kan ikke være tom.");
            return;
        }

        Console.Write("Forfatter: ");
        string forfatter = Console.ReadLine();

        if (string.IsNullOrWhiteSpace(forfatter))
        {
            Console.WriteLine("Feil: forfatter kan ikke være tom.");
            return;
        }

        Console.Write("År: ");
        string aarInput = Console.ReadLine();
        int aar;
        if (!int.TryParse(aarInput, out aar) || aar < 1000 || aar > DateTime.Now.Year)
        {
            Console.WriteLine("Feil: ugyldig årstall.");
            return;
        }

        Console.Write("Antall eksemplarer: ");
        string antallInput = Console.ReadLine();
        int antall;
        if (!int.TryParse(antallInput, out antall) || antall <= 0)
        {
            Console.WriteLine("Feil: antall må være et positivt tall.");
            return;
        }

        bibliotek.RegistrerBok(new Bok(id, tittel, forfatter, aar, antall));
        Console.WriteLine("Bok registrert!");
    }
