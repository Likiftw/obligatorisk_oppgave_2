    static void SeAktiveLan()
    {
        bool funnett = false;
        foreach (Lan l in bibliotek.Lan)
        {
            if (l.ErAktiv == true)
            {
                Console.WriteLine(l.Bruker.Navn + " har lånt \"" + l.Bok.Tittel + "\" siden " + l.Utlaansdato.ToShortDateString());
                funnett = true;
            }
        }

        if (funnett == false)
        {
            Console.WriteLine("Ingen aktive lån.");
        }
    }

    static void SeLanehistorikk()
    {
        if (bibliotek.Lan.Count == 0)
        {
            Console.WriteLine("Ingen lånehistorikk.");
            return;
        }

        foreach (Lan l in bibliotek.Lan)
        {
            string status = l.ErAktiv ? "Aktiv" : "Returnert " + l.Returdato.ToShortDateString();
            Console.WriteLine(l.Bruker.Navn + " - \"" + l.Bok.Tittel + "\" - Lånt: " + l.Utlaansdato.ToShortDateString() + " - " + status);
        }
    }

