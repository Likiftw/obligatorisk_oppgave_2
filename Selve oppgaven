using System;
using System.Collections.Generic;

// ========== BRUKERKLASSER ==========
public abstract class Bruker
{
    public string Navn { get; set; }
    public string Epost { get; set; }
    public string Brukernavn { get; set; }
    public string Passord { get; set; }
    public string Rolle { get; set; }

    protected Bruker(string navn, string epost, string brukernavn, string passord, string rolle)
    {
        Navn = navn;
        Epost = epost;
        Brukernavn = brukernavn;
        Passord = passord;
        Rolle = rolle;
    }
}

public class Student : Bruker
{
    public string StudentID { get; set; }
    public List<Kurs> Kurs { get; set; } = new List<Kurs>();
    public List<Karakter> Karakterer { get; set; } = new List<Karakter>();

    public Student(string studentID, string navn, string epost, string brukernavn, string passord)
        : base(navn, epost, brukernavn, passord, "Student")
    {
        StudentID = studentID;
    }
}

public class Faglarer : Bruker
{
    public string AnsattID { get; set; }
    public string Avdeling { get; set; }
    public List<Kurs> MineKurs { get; set; } = new List<Kurs>();

    public Faglarer(string ansattID, string navn, string epost, string brukernavn, string passord, string avdeling)
        : base(navn, epost, brukernavn, passord, "Faglarer")
    {
        AnsattID = ansattID;
        Avdeling = avdeling;
    }
}

public class Bibliotekar : Bruker
{
    public string AnsattID { get; set; }

    public Bibliotekar(string ansattID, string navn, string epost, string brukernavn, string passord)
        : base(navn, epost, brukernavn, passord, "Bibliotekar")
    {
        AnsattID = ansattID;
    }
}

